{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "github>home-operations/renovate-presets//versioning/searxng.json5#2.1.0",
  ],
  packageRules: [
    {
      "description": "Use custom versioning for Firefly",
      "matchDatasources": ["docker"],
      "versioning": "regex:^version-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$",
      "matchPackagePatterns": ["fireflyiii/core", "fireflyiii/data-importer"]
    },
    {
      description: ["Loose versioning for bambuddy"],
      matchDatasources: ["docker"],
      allowedVersions: "/^\\d+\\.\\d+\\.\\d+(\\.\\d+)?$/",
      versioning: "loose",
      matchPackageNames: ["ghcr.io/maziggy/bambuddy"],
    }
  ]
}
